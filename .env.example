# =============================================================================
# Course environment configuration — TEMPLATE (safe to commit).
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Setup for this learner (2026-07):
#   - All course lessons route through the z.ai gateway, which exposes an
#     Anthropic-compatible API. We reuse the SAME key that powers the `pi`
#     coding agent, so NO new API keys were provisioned.
#   - Access confirmed for: claude-opus-4-5, claude-sonnet-4-5, glm-4.6,
#     glm-4.5 via the `anthropic` Python SDK.
#   - The OpenAI-compatible endpoint (/api/v1/...) returns model_access_denied
#     on this key, so prefer the `anthropic` SDK in lesson code.
# =============================================================================

# --- LLM provider (Anthropic-compatible, points at z.ai gateway) ---
# These three mirror the shell vars already set for `pi`. Lessons that build an
# `Anthropic()` client with no args inherit them automatically.
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=your_z_ai_token_here

# --- Default model used by lesson smoke-tests / helpers ---
# Pick one of: claude-sonnet-4-5 (balanced), claude-opus-4-5 (best/slowest),
# glm-4.5 or glm-4.6 (cheapest). Change per lesson as needed.
COURSE_DEFAULT_MODEL=claude-sonnet-4-5

# --- Hugging Face (optional, for datasets / model downloads) ---
# Needed from Phase 5+ (NLP) and Phase 7 (Transformers) for some gated repos.
# Create at https://huggingface.co/settings/tokens (read scope).
# HF_TOKEN=hf_your_read_token_here

# --- Optional providers (only if a specific lesson needs them) ---
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
